# ── Base de datos (Supabase) ─────────────────────────────────
# Settings > Database > Connection String (URI mode, con tu contraseña)
DATABASE_URL=postgresql://postgres:[TU-CONTRASEÑA]@db.[TU-ID].supabase.co:5432/postgres

# ── Auth JWT ──────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_minimo_32_caracteres_aleatorios
JWT_REFRESH_SECRET=cambia_esto_otro_secreto_diferente_minimo_32

# ── IA gratuita ───────────────────────────────────────────────
# Groq (análisis de sueños): console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# HuggingFace (embeddings): huggingface.co → Settings → Access Tokens
HUGGINGFACE_API_KEY=hf_...

# ── Email (Resend - gratis 100/día) ──────────────────────────
# resend.com → API Keys
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_...
SMTP_FROM=noreply@tudominio.com

# ── App ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
